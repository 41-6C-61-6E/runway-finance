# ─── Next Auth ──────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
NEXTAUTH_SECRET=<64-char-hex>
NEXTAUTH_URL=http://localhost:3001

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/runway_finance

# ─── Encryption ──────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=<64-char-hex-string>

# ─── Registration Control ────────────────────────────────────────────────────
# Set to "false" after the first user registers
ALLOW_REGISTRATION=true
# Registration PIN — set to require a PIN for new account creation (leave empty to disable)
REGISTRATION_PIN=

# ─── FRED API (optional — for historical home price estimation) ───────────────
# Get a free API key at: https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=

# ─── OAuth (optional — remove if not using) ───────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=