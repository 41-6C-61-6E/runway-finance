{
  "name": "personal-finance",
  "description": "Self-hosted personal finance dashboard for net worth, cash flow, budgets, goals, real estate, and FIRE planning.",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "generate-colors": "node scripts/generate-css-from-palette.mjs",
    "dev": "DISABLE_WORKER_THREADS=true NODE_OPTIONS='--max-old-space-size=1024' node scripts/generate-css-from-palette.mjs && node scripts/generate-sw.mjs && next dev --turbo -p 3000",
    "build": "node scripts/generate-css-from-palette.mjs && node scripts/generate-sw.mjs && next build",
    "start": "next start -p 3000",
    "preview": "next start -p 3000",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx .",
    "ci": "pnpm -s lint && pnpm -s typecheck && pnpm -s build",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:docker": "bash ./scripts/test-docker.sh",
    "test:integration": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/personal_finance vitest run --config vitest.integration.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:indexes": "tsx lib/db/seed-indexes.ts",
    "generate-pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "upgrade": "next upgrade",
    "generate-vapid-keys": "node scripts/generate-vapid-keys.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.1.17",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/analytics": "^1.6.1",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.554.0",
    "next": "^16.2.6",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "plaid": "^42.2.0",
    "postcss": "^8.5.15",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-plaid-link": "^4.1.1",
    "recharts": "^3.1.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.1.17",
    "web-push": "^3.6.7",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/archiver": "^7.0.0",
    "@types/node": "24.10.1",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.7",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "9.39.1",
    "jsdom": "^29.1.1",
    "prettier": "3.6.2",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "flatted": "3.4.2",
      "minimatch@3": "3.1.3",
      "esbuild@<0.25.0": "0.25.2"
    }
  }
}
