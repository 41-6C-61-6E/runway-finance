import { describe, it, expect, vi, beforeEach } from 'vitest';
import { calculateWealthFlow } from '@/lib/services/wealth-flow';
import { accounts, accountSnapshots, userSettings } from '@/lib/db/schema';

let mockAccounts: any[] = [];
let mockSnapshots: any[] = [];
let mockUserSettings: any[] = [];
let dbCallIndex = 0;
let groupByCallCount = 0;
let nonGroupByCallCount = 0;

class MockDbQueryBuilder {
  private _table: any;
  private _isGroupBy = false;

  select(...args: any[]) { return this; }
  from(table: any) { this._table = table; return this; }
  where(...args: any[]) { return this; }
  inArray(...args: any[]) { return this; }
  groupBy(...args: any[]) { this._isGroupBy = true; return this; }
  limit(...args: any[]) { return this; }

  async then(onfulfilled?: (value: any) => any) {
    dbCallIndex++;
    let result: any = [];
    const isGb = this._isGroupBy;
    this._isGroupBy = false;

    console.log(`Call #${dbCallIndex}: table=${this._table?.table?.name || this._table?.name || '?'}, groupBy=${isGb}`);

    if (this._table === userSettings) {
      result = mockUserSettings;
    } else if (this._table === accounts) {
      result = mockAccounts;
    } else if (this._table === accountSnapshots) {
      if (isGb) {
        groupByCallCount++;
        const targetDate = groupByCallCount === 1 ? '2026-05-31' : '2026-06-30';
        console.log(`  GroupBy #${groupByCallCount}, target=${targetDate}`);
        const uniqueAccts = Array.from(new Set(mockSnapshots.map((s: any) => s.accountId)));
        result = uniqueAccts.map((accId: string) => {
          const snaps = mockSnapshots.filter((s: any) => s.accountId === accId && s.snapshotDate <= targetDate);
          if (snaps.length === 0) return null;
          const maxDate = snaps.reduce((max: string, s: any) => s.snapshotDate > max ? s.snapshotDate : max, '');
          return { accountId: accId, maxDate };
        }).filter(Boolean);
        console.log(`  -> ${JSON.stringify(result)}`);
      } else {
        nonGroupByCallCount++;
        const targetDate = nonGroupByCallCount === 1 ? '2026-05-31' : '2026-06-30';
        console.log(`  Select #${nonGroupByCallCount}, target=${targetDate}`);
        const uniqueAccts = Array.from(new Set(mockSnapshots.map((s: any) => s.accountId)));
        result = uniqueAccts.map((accId: string) => {
          const snaps = mockSnapshots.filter((s: any) => s.accountId === accId && s.snapshotDate <= targetDate);
          if (snaps.length === 0) return null;
          const maxDate = snaps.reduce((max: string, s: any) => s.snapshotDate > max ? s.snapshotDate : max, '');
          const match = snaps.find((s: any) => s.snapshotDate === maxDate);
          return match ? { accountId: match.accountId, balance: match.balance } : null;
        }).filter(Boolean);
        console.log(`  -> ${JSON.stringify(result)}`);
      }
    }

    return Promise.resolve(result).then(onfulfilled);
  }
}

vi.mock('@/lib/db', () => ({
  getDb: () => new MockDbQueryBuilder(),
}));

vi.mock('@/lib/crypto', () => ({
  decryptField: async (val: string) => val,
  decryptRows: async (table: string, rows: any[]) => rows,
}));

vi.mock('@/lib/services/account-history', () => ({
  convertCurrency: (amount: number) => amount,
  roundToCents: (val: number) => Math.round(val * 100) / 100,
}));

describe('debug', () => {
  const mockDek = new Uint8Array(32);

  beforeEach(() => {
    mockAccounts = [];
    mockSnapshots = [];
    mockUserSettings = [{ currency: 'USD', showImportedData: { global: true, cashFlowProjections: true }, paystubEnabled: true }];
    dbCallIndex = 0;
    groupByCallCount = 0;
    nonGroupByCallCount = 0;
  });

  it('debug positive', async () => {
    mockAccounts = [
      { id: 'checking-1', userId: 'user_1', name: 'Checking', type: 'checking', currency: 'USD', isHidden: false, isExcludedFromNetWorth: false },
      { id: 'savings-1', userId: 'user_1', name: 'Savings', type: 'savings', currency: 'USD', isHidden: false, isExcludedFromNetWorth: false },
    ];
    mockSnapshots = [
      { accountId: 'checking-1', snapshotDate: '2026-05-31', balance: '1000.00' },
      { accountId: 'savings-1', snapshotDate: '2026-05-31', balance: '5000.00' },
      { accountId: 'checking-1', snapshotDate: '2026-06-30', balance: '3000.00' },
      { accountId: 'savings-1', snapshotDate: '2026-06-30', balance: '5500.00' },
    ];

    const result = await calculateWealthFlow('user_1', '2026-06-01', '2026-06-30', mockDek);
    
    console.log('\nRESULT SUMMARY:', JSON.stringify(result.summary, null, 2));
    console.log('NODES:', JSON.stringify(result.nodes.map(n => ({ id: n.id, label: n.label, value: n.value, type: n.type })), null, 2));
    
    expect(result.summary.beginningNetWorth).toBe(6000);
    expect(result.summary.endingNetWorth).toBe(8500);
    expect(result.summary.netWorthChange).toBe(2500);
  });
});
